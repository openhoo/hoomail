{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Hoomail Helm values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "replicaCount": { "type": "integer", "const": 1, "description": "Hoomail uses one writable SQLite database and supports exactly one replica." },
    "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
    "image": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "tag": { "type": "string" },
        "digest": { "type": "string", "pattern": "^$|^sha256:[0-9a-f]{64}$" }
      },
      "required": ["repository", "pullPolicy", "tag", "digest"]
    },
    "imagePullSecrets": { "type": "array", "items": { "type": "object" } },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object" },
        "automount": { "type": "boolean", "const": false },
        "name": { "type": "string" }
      },
      "required": ["create", "annotations", "automount", "name"]
    },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "ports": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "http": { "$ref": "#/definitions/port" },
        "smtp": { "$ref": "#/definitions/port" },
        "pop3": { "$ref": "#/definitions/port" }
      },
      "required": ["http", "smtp", "pop3"]
    },
    "service": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "annotations": { "type": "object" },
        "ports": {
          "type": "object", "additionalProperties": false,
          "properties": {
            "http": { "$ref": "#/definitions/port" },
            "smtp": { "$ref": "#/definitions/port" },
            "pop3": { "$ref": "#/definitions/port" }
          },
          "required": ["http", "smtp", "pop3"]
        }
      },
      "required": ["type", "annotations", "ports"]
    },
    "ingress": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array", "minItems": 1,
                "items": {
                  "type": "object", "additionalProperties": false,
                  "properties": {
                    "path": { "type": "string", "minLength": 1 },
                    "pathType": { "type": "string", "enum": ["Exact", "Prefix", "ImplementationSpecific"] }
                  },
                  "required": ["path", "pathType"]
                }
              }
            },
            "required": ["host", "paths"]
          }
        },
        "tls": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["enabled", "className", "annotations", "hosts", "tls"]
    },
    "persistence": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "existingClaim": { "type": "string" },
        "storageClass": { "type": "string" },
        "accessModes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "size": { "type": "string", "pattern": "^[1-9][0-9]*(Ei|Pi|Ti|Gi|Mi|Ki)$" },
        "annotations": { "type": "object" },
        "selector": { "type": "object" }
      },
      "required": ["enabled", "existingClaim", "storageClass", "accessModes", "size", "annotations", "selector"]
    },
    "resources": { "type": "object" },
    "livenessProbe": { "$ref": "#/definitions/probe" },
    "readinessProbe": { "$ref": "#/definitions/probe" },
    "startupProbe": { "$ref": "#/definitions/probe" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array", "items": { "type": "object" } },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array", "items": { "type": "object" } }
  },
  "required": [
    "replicaCount", "revisionHistoryLimit", "image", "imagePullSecrets", "nameOverride", "fullnameOverride",
    "serviceAccount", "podAnnotations", "podLabels", "podSecurityContext", "securityContext", "ports", "service",
    "ingress", "persistence", "resources", "livenessProbe", "readinessProbe", "startupProbe", "nodeSelector",
    "tolerations", "affinity", "topologySpreadConstraints"
  ],
  "definitions": {
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "probe": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 }
      },
      "required": ["enabled", "initialDelaySeconds", "periodSeconds", "timeoutSeconds", "failureThreshold"]
    }
  }
}
